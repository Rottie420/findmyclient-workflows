    {
      "parameters": {
        "jsCode": "// Clean the escaped quotes and trim the trailing newline\nconst cleanOutput = $input.first().json.output.replace(/\\\\\"/g, '\"').trim();\n\n// If the string still starts and ends with external quotes, strip them\nconst finalString = cleanOutput.startsWith('\"') && cleanOutput.endsWith('\"') \n  ? cleanOutput.slice(1, -1) \n  : cleanOutput;\n\nconst data = JSON.parse(finalString);\n\nreturn data.items.map(item => ({\n  json: {\n    query: item\n  }\n}));\n"
      },
