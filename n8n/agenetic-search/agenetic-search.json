    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfor (const item of items) {\n  if (Array.isArray(item.json.rows)) {\n    for (const row of item.json.rows) {\n      if (Array.isArray(row.risk)) {\n        row.risk = row.risk.join(', ');\n      }\n    }\n  }\n}\n\nreturn items;"
      },
