    },
    {
      "parameters": {
        "jsCode": "return $input.all()\n  .filter(item =>\n    item.json &&\n    item.json.verified == 1 &&\n    item.json.email &&\n    item.json.outreach !== \"sent\"\n  )\n  .map(item => ({\n    json: {\n      id: item.json.id,\n      email: item.json.email,\n      name: item.json.prefix || ''\n    }\n  }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3280,
        832
      ],
      "id": "45ecd8ea-a4d1-48be-8f30-b43a2e1622e5",
      "name": "Filter Leads"
    },
    {
      "parameters": {
        "fromEmail": "no-reply@mg.findmyclient.org",
        "toEmail": "={{ $json.email }}",
        "emailFormat": "text",
        "text": "=hi {{ $json.name }}\n\nI came across your company and wanted to reach out.\n\nWe help businesses connect with high-quality B2B leads.\n\nWould you like to see a sample list?\n",
        "options": {
          "appendAttribution": false
        }
      },
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
