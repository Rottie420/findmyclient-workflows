      "name": "Send Email",
      "webhookId": "7f5b106e-cc3e-43f0-ac42-2c3ab34345bb",
      "executeOnce": false
    },
    {
      "parameters": {
        "jsCode": "const accepted = $input.first().json.accepted;\n\nreturn accepted.map(email => {\n  return {\n    json: {\n      email: email,\n      outreach: \"sent\"\n    }\n  };\n});"
      },
